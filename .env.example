# Copier vers .env.local et renseigner les valeurs.

# URL canonique du site (optionnel — sinon https:// + domaine dans l’admin / défaut)
# VITE_SITE_URL=https://laplaceluxopuncture.fr

# Admin (optionnel — sinon défaut code)
# VITE_ADMIN_IDENTIFIER=
# VITE_ADMIN_PASSWORD=

# Analytics (optionnel)
# VITE_ANALYTICS_INGEST_URL=

# Le formulaire contact (page /contact) envoie vers l’email des coordonnées admin
